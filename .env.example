# ============================================================
# INSIGHT FORGE V2.0 — UNIFIED ENVIRONMENT CONFIGURATION
# ============================================================

# General Config
APP_NAME=Insight Forge
APP_VERSION=2.0.0
APP_ENV=development
DEBUG=true

# Port Configuration
BACKEND_PORT=8000
FRONTEND_PORT=3000

# PostgreSQL Configuration
POSTGRES_USER=insight_forge_user
POSTGRES_PASSWORD=insight_forge_password
POSTGRES_DB=insight_forge_db
DATABASE_URL=postgresql+asyncpg://insight_forge_user:insight_forge_password@postgres:5432/insight_forge_db
MIGRATION_DATABASE_URL=postgresql://insight_forge_user:insight_forge_password@postgres:5432/insight_forge_db

# Redis
REDIS_URL=redis://redis:6379/0

# Security (JWT_SECRET / SECRET_KEY must be at least 32 characters long)
SECRET_KEY=default-secret-key-32-characters-long-secret
JWT_SECRET=default-secret-key-32-characters-long-secret
JWT_SECRET_KEY=default-secret-key-32-characters-long-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15

# Celery
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# Logging
LOG_LEVEL=INFO

# Frontend Config
NEXT_PUBLIC_API_URL=http://localhost:8000
