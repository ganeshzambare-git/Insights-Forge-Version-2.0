# ============================================================
# INSIGHT FORGE V2.0 — ENVIRONMENT CONFIGURATION TEMPLATE
# ============================================================

# Application
APP_NAME=Insight Forge
APP_VERSION=2.0.0
APP_ENV=development
DEBUG=true

# Database — Neon PostgreSQL
# Add the Neon connection string when received from the team.
DATABASE_URL=

# Security (SECRET_KEY/JWT_SECRET must be at least 32 characters long)
SECRET_KEY=
JWT_PRIVATE_KEY_PATH=
JWT_PUBLIC_KEY_PATH=
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15

# Redis
REDIS_URL=

# Celery
CELERY_BROKER_URL=
CELERY_RESULT_BACKEND=

# Logging
LOG_LEVEL=INFO